// ============================================================
// GAME LOGIC — no DOM, no rendering, pure state + functions
// ============================================================

export function newState() {
  return {
    year: 1,
    maxYears: 30,
    cash: 10_000,
    income: 5_000,
    indexFund: { shares: 0, price: 100.0, history: [100.0] },
    bonds: { units: 0, price: 100.0, coupon: 0.03, history: [100.0] },
    crypto: { coins: 0, price: 50.0, history: [50.0] },
    // track net worth over time for graphing
    netWorthHistory: [10_000],
    log: [],
  };
}

export function portfolioValue(state) {
  const indexValue = state.indexFund.shares * state.indexFund.price;
  const bondsValue = (state.bonds?.units || 0) * (state.bonds?.price || 0);
  const cryptoValue = (state.crypto?.coins || 0) * (state.crypto?.price || 0);
  return indexValue + bondsValue + cryptoValue;
}

export function netWorth(state) {
  return state.cash + portfolioValue(state);
}

export function buy(state, qty) {
  const cost = qty * state.indexFund.price;
  if (cost > state.cash) {
    return { ...state, log: [...state.log, { msg: `Need $${fmt(cost)} — only have $${fmt(state.cash)}.`, type: "bad" }] };
  }
  const newCash = state.cash - cost;
  const newShares = state.indexFund.shares + qty;
  const nextState = {
    ...state,
    cash: newCash,
    indexFund: { ...state.indexFund, shares: newShares },
    log: [...state.log, { msg: `Bought ${qty} share(s) @ $${state.indexFund.price.toFixed(2)}.`, type: "good" }],
  };
  return { ...nextState, netWorthHistory: [...(state.netWorthHistory || []), Math.round(netWorth(nextState))] };
}

export function sell(state, qty) {
  if (qty > state.indexFund.shares) {
    return { ...state, log: [...state.log, { msg: `Only have ${state.indexFund.shares} shares.`, type: "bad" }] };
  }
  const proceeds = qty * state.indexFund.price;
  const newCash = state.cash + proceeds;
  const newShares = state.indexFund.shares - qty;
  const nextState = {
    ...state,
    cash: newCash,
    indexFund: { ...state.indexFund, shares: newShares },
    log: [...state.log, { msg: `Sold ${qty} share(s) @ $${state.indexFund.price.toFixed(2)}.`, type: "info" }],
  };
  return { ...nextState, netWorthHistory: [...(state.netWorthHistory || []), Math.round(netWorth(nextState))] };
}

